{
    auto_https off
    admin off
}

{$SERVER_NAME:localhost} {
    root * /app/public

    # Enable FrankenPHP
    php_server

    # Prevent access to sensitive files
    @disallowed {
        path /.env*
        path /storage/*
        path /.git/*
        file {
            try_files {path}
        }
    }
    respond @disallowed 404

    # Serve static files or fallthrough to PHP
    file_server

    # Handle Laravel routes
    try_files {path} {path}/ /index.php?{query}

    # PHP configuration
    encode gzip

    # Logs
    log {
        output stdout
        format console
    }
}
